#include <stdio.h>
#include <ctype.h>
int main() {
    char str[] = "The quick brown fox jumps over the lazy dog";
    int alpha[26] = {0};

    for(int i=0; str[i]; i++) {
        if(isalpha(str[i]))
            alpha[tolower(str[i]) - 'a'] = 1;
    }

    for(int i=0;i<26;i++) {
        if(alpha[i]==0) {
            printf("Not Pangram");
            return 0;
        }
    }

    printf("Pangram");
    return 0;
}
