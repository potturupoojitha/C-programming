#include <stdio.h>
int main() {
    char a[]="hello", b[]="world";

    for(int i=0;a[i];i++) {
        int found=0;
        for(int j=0;b[j];j++) {
            if(a[i]==b[j]) {
                found=1;
                break;
            }
        }
        if(!found)
            printf("%c", a[i]);
    }
    return 0;
}
