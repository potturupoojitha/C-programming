// Program: Octal to Decimal
#include <stdio.h>

int main() {
    int octal, decimal = 0, base = 1, rem;

    scanf("%d", &octal);

    while(octal > 0) {
        rem = octal % 10;
        decimal += rem * base;
        octal /= 10;
        base *= 8;
    }

    printf("Decimal = %d", decimal);

    return 0;
}
