#include <stdio.h>
int main() {
    char str[] = "programming";

    for(int i=0; str[i]; i++) {
        for(int j=i+1; str[j]; j++) {
            if(str[i] == str[j]) {
                for(int k=j; str[k]; k++)
                    str[k] = str[k+1];
                j--;
            }
        }
    }

    printf("%s", str);
    return 0;
}
