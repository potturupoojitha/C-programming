#include <stdio.h>
int main() {
    int arr[] = {5,1,4,2,8};
    int n = 5, max = arr[0], second = -1;

    for(int i=0;i<n;i++) {
        if(arr[i] > max) {
            second = max;
            max = arr[i];
        } else if(arr[i] > second && arr[i] != max) {
            second = arr[i];
        }
    }

    printf("Second largest = %d", second);
    return 0;
}
