#include <stdio.h>

int digitSum(int n) {
    int sum = 0;
    while(n > 0) {
        sum += n % 10;
        n /= 10;
    }
    return sum;
}

int main() {
    int n;
    printf("Enter number: ");
    scanf("%d", &n);

    int temp = n;
    while(temp > 9) {
        temp = digitSum(temp);
    }

    if(temp == 1)
        printf("Magic Number");
    else
        printf("Not Magic Number");

    return 0;
}
