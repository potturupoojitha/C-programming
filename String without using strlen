#include <stdio.h>
#include <string.h>
int main() {
    char a[]="abc", b[]="ac";
    int dp[10][10]={0};

    for(int i=1;i<=strlen(a);i++) {
        for(int j=1;j<=strlen(b);j++) {
            if(a[i-1]==b[j-1])
                dp[i][j]=dp[i-1][j-1]+1;
            else
                dp[i][j]=(dp[i-1][j]>dp[i][j-1])?dp[i-1][j]:dp[i][j-1];
        }
    }

    printf("LCS length = %d", dp[strlen(a)][strlen(b)]);
    return 0;
}
