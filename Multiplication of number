#include <stdio.h>
int main() {
    char s1[] = "hello", s2[] = "hello";
    int i=0, flag=1;

    while(s1[i] != '\0' || s2[i] != '\0') {
        if(s1[i] != s2[i]) {
            flag = 0;
            break;
        }
        i++;
    }

    if(flag)
        printf("Equal");
    else
        printf("Not Equal");

    return 0;
}
