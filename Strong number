#include <stdio.h>

int factorial(int n) {
    int fact = 1;
    for(int i = 1; i <= n; i++)
        fact *= i;
    return fact;
}

int main() {
    int n, sum = 0, temp;

    printf("Enter number: ");
    scanf("%d", &n);

    temp = n;
    while(n > 0) {
        int d = n % 10;
        sum += factorial(d);
        n /= 10;
    }

    if(sum == temp)
        printf("Strong Number");
    else
        printf("Not Strong Number");

    return 0;
}
